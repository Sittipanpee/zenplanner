{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sentry_alert",
  "title": "Sentry Alert",
  "description": "Sentinel cell → CO on detection of failure or degraded state.",
  "type": "object",
  "required": ["type", "from", "to", "priority", "sentry", "status", "created_at"],
  "properties": {
    "type": { "const": "sentry_alert" },
    "from": { "enum": ["build-sentry", "type-sentry", "test-sentry", "security-auditor", "conflict-hawk"] },
    "to": { "const": "chief-orchestrator" },
    "priority": { "enum": ["normal", "high", "critical"] },
    "sentry": { "enum": ["build", "type", "test", "security", "conflict"] },
    "status": { "enum": ["pass", "fail", "degraded"] },
    "created_at": { "type": "string", "format": "date-time" },
    "error_count": { "type": "integer", "minimum": 0 },
    "violation": {
      "enum": ["cross_dept_write", "co_only_write", "readonly_write", "secret_leak", "rls_gap"]
    },
    "agent": { "type": "string" },
    "offender": { "type": "string" },
    "owner": { "type": "string" },
    "path": { "type": "string" },
    "duration_ms": { "type": "integer" }
  }
}
